generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model clients {
  id               String        @id
  userId           String
  cnpj             String
  companyName      String
  cnaeMain         String
  employeesCount   Int           @default(0)
  revenueLast12m   Decimal       @db.Decimal(15, 2)
  payrollLast12m   Decimal       @db.Decimal(15, 2)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime
  activityDesc     String?
  adminExpense     Decimal?      @db.Decimal(15, 2)
  benefits         Decimal?      @db.Decimal(15, 2)
  clientCount      Int?
  cnaeSecondary    String?
  companySize      CompanySize?
  currentCOFINS    Decimal?      @db.Decimal(10, 2)
  currentCSLL      Decimal?      @db.Decimal(10, 2)
  currentDAS       Decimal?      @db.Decimal(10, 2)
  currentICMS      Decimal?      @db.Decimal(10, 2)
  currentINSS      Decimal?      @db.Decimal(10, 2)
  currentIRPJ      Decimal?      @db.Decimal(10, 2)
  currentISS       Decimal?      @db.Decimal(10, 2)
  currentPIS       Decimal?      @db.Decimal(10, 2)
  fantasyName      String?
  legalNature      LegalNature?
  logisticExpense  Decimal?      @db.Decimal(15, 2)
  marketingExpense Decimal?      @db.Decimal(15, 2)
  openingDate      DateTime?
  proLabore        Decimal?      @db.Decimal(15, 2)
  rentExpense      Decimal?      @db.Decimal(15, 2)
  revenueComercio  Decimal?      @db.Decimal(15, 2)
  revenueLocacao   Decimal?      @db.Decimal(15, 2)
  revenueOutros    Decimal?      @db.Decimal(15, 2)
  revenueServicos  Decimal?      @db.Decimal(15, 2)
  revenueType      RevenueType?
  sazonality       String?
  simplesOpt       Boolean?
  supplierExpense  Decimal?      @db.Decimal(15, 2)
  taxRegime        TaxRegime?
  ticketMedio      Decimal?      @db.Decimal(10, 2)
  totalSalary      Decimal?      @db.Decimal(15, 2)
  municipio        String?
  municipioIBGE    String?
  uf               String?
  users            users         @relation(fields: [userId], references: [id], onDelete: Cascade)
  simulations      simulations[]
}

model cnae_codes {
  id            String   @id
  code          String   @unique
  description   String
  anexoSimples  String
  canBeSimples  Boolean  @default(true)
  issPercentage Decimal? @db.Decimal(4, 2)
  createdAt     DateTime @default(now())
  updatedAt     DateTime
}

model iss_rates {
  id            String   @id
  ibgeCode      String   @unique
  cityName      String
  stateCode     String
  issRate       Decimal  @db.Decimal(4, 2)
  effectiveDate DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime
}

model simples_rates {
  id             String   @id
  anexo          String
  faixa          Int
  limiteInferior Decimal  @db.Decimal(15, 2)
  limiteSuperior Decimal  @db.Decimal(15, 2)
  aliquota       Decimal  @db.Decimal(5, 4)
  deducao        Decimal  @db.Decimal(15, 2)
  effectiveYear  Int      @default(2026)
  createdAt      DateTime @default(now())
  updatedAt      DateTime
  percentualCPP  Decimal  @default(0) @db.Decimal(5, 4)

  @@unique([anexo, faixa])
}

model simulations {
  id             String   @id
  clientId       String
  createdAt      DateTime @default(now())
  inputData      Json
  resultData     Json
  selectedRegime String?
  clients        clients  @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model users {
  id                   String    @id
  email                String    @unique
  name                 String?
  planTier             PlanTier  @default(FREE)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime
  agencyColor          String?   @default("#2563eb")
  agencyLogo           String?
  agencyName           String?
  agencyWebsite        String?
  agencyColorSecondary String?   @default("#1e40af")
  clients              clients[]
}

enum PlanTier {
  FREE
  PRO
  AGENCY
}

enum TaxRegime {
  SIMPLES_NACIONAL
  LUCRO_PRESUMIDO
  LUCRO_REAL
  MEI
}

enum LegalNature {
  LTDA
  SLU
  MEI
  EI
  SA
  EIRELI
}

enum CompanySize {
  ME
  EPP
  DEMAIS
}

enum RevenueType {
  SERVICOS
  COMERCIO
  INDUSTRIA
  LOCACAO
  MISTO
}
