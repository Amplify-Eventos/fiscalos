// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Enum para o plano do usuário
enum PlanTier {
  FREE
  PRO
  AGENCY
}

// Enum para regime tributário
enum TaxRegime {
  SIMPLES_NACIONAL
  LUCRO_PRESUMIDO
  LUCRO_REAL
}

// Enum para natureza jurídica
enum LegalNature {
  MEI
  ME
  EPP
  LTDA
  SA
  SLU
}

// Enum para porte da empresa
enum CompanySize {
  MEI
  ME
  EPP
  DEMAIS
}

// Usuário (contador)
model User {
  id           String     @id @default(uuid())
  email        String     @unique
  name         String?
  planTier     PlanTier   @default(FREE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  clients      Client[]
}

// Cliente (empresa do cliente do contador)
model Client {
  id                  String      @id @default(uuid())
  userId              String
  user                User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Dados Jurídicos
  cnpj                String
  companyName         String
  legalNature         LegalNature?
  companySize         CompanySize?
  taxRegime           TaxRegime   @default(SIMPLES_NACIONAL)
  cnaeMain            String
  cnaeSecondary       String?
  
  // Localização
  municipio           String?
  municipioIBGE       String?
  uf                  String?
  
  // Dados Financeiros
  revenueLast12m      Decimal     @default(0)
  revenueServicos     Decimal?
  revenueComercio     Decimal?
  revenueLocacao      Decimal?
  revenueOutros       Decimal?
  payrollLast12m      Decimal     @default(0)
  
  // Custos
  rentExpense         Decimal?
  supplierExpense     Decimal?
  marketingExpense    Decimal?
  adminExpense        Decimal?
  
  // Dados Trabalhistas
  employeesCount      Int         @default(0)
  totalSalary         Decimal?
  proLabore           Decimal?
  benefits            Decimal?
  
  // Impostos Atuais
  currentDAS          Decimal?
  currentIRPJ         Decimal?
  currentCSLL         Decimal?
  currentPIS          Decimal?
  currentCOFINS       Decimal?
  currentISS          Decimal?
  currentICMS         Decimal?
  currentINSS         Decimal?
  
  // Tipo de receita principal
  revenueType         String?
  
  // Timestamps
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  
  simulations         Simulation[]
  
  @@index([userId])
  @@index([cnpj])
}

// Simulação (histórico)
model Simulation {
  id              String    @id @default(uuid())
  clientId        String
  client          Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  // Dados da simulação
  inputData       Json      // Dados de entrada
  resultData      Json      // Resultado completo
  
  createdAt       DateTime  @default(now())
  
  @@index([clientId])
}

// Faixas do Simples Nacional
model SimplesRate {
  id              String    @id @default(uuid())
  anexo           String    // I, II, III, IV, V
  faixa           Int       // 1 a 6
  limiteInferior  Decimal
  limiteSuperior  Decimal
  aliquota        Decimal   // Ex: 0.1400 = 14%
  deducao         Decimal
  percentualCPP   Decimal?
  
  @@unique([anexo, faixa])
  @@index([anexo])
}

// Alíquotas de ISS por município
model IssRate {
  id          String    @id @default(uuid())
  ibgeCode    String    @unique
  cityName    String
  stateCode   String
  issRate     Decimal   // Ex: 0.05 = 5%
  
  @@index([ibgeCode])
}

// Mapeamento CNAE → Anexo Simples
model CnaeCode {
  id            String    @id @default(uuid())
  code          String    @unique
  description   String?
  anexoSimples  String    // I, II, III, IV, V
  
  @@index([code])
}
